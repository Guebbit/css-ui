{
  "name": "@guebbit/css-ui",
  "type": "module",
  "version": "1.2.0",
  "description": "CSS UI",
  "style": "./dist/css-ui.css",
  "sass": "./index.scss",
  "exports": {
    ".": {
      "sass": "./index.scss",
      "style": "./dist/css-ui.css",
      "default": "./dist/css-ui.css"
    },
    "./core": {
      "sass": "./src/_generics/core.scss",
      "style": "./dist/core.css"
    },
    "./components": {
      "sass": "./src/index.scss",
      "style": "./dist/components.css"
    },
    "./components/atoms": {
      "sass": "./src/components/atoms/_index.scss"
    },
    "./components/molecules": {
      "sass": "./src/components/molecules/_index.scss"
    },
    "./components/organisms": {
      "sass": "./src/components/organisms/_index.scss"
    },
    "./atoms": {
      "sass": "./src/components/atoms/_index.scss"
    },
    "./atoms/button-simple": {
      "sass": "./src/components/atoms/button-simple/index.scss"
    },
    "./atoms/*": {
      "sass": "./src/components/atoms/*/index.scss"
    },
    "./molecules": {
      "sass": "./src/components/molecules/_index.scss"
    },
    "./molecules/*": {
      "sass": "./src/components/molecules/*/index.scss"
    },
    "./organisms": {
      "sass": "./src/components/organisms/_index.scss"
    },
    "./organisms/*": {
      "sass": "./src/components/organisms/*/index.scss"
    },
    "./utilities": {
      "sass": "./src/_generics/utilities/_index.scss",
      "style": "./dist/utilities.css"
    },
    "./settings": {
      "sass": "./_settings.scss"
    },
    "./tools": {
      "sass": "./_tools.scss"
    },
    "./styles": {
      "sass": "./_styles.scss"
    }
  },
  "scripts": {
    "dev": "npm run docs:dev",
    "build": "node build.js",
    "docs:dev": "vitepress dev docs --port 8080",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs --port 8080",
    "lint:styles": "stylelint \"**/*.{css,scss}\"",
    "lint:md": "markdownlint-cli2",
    "lint:js": "eslint .",
    "lint": "npm run lint:styles && npm run lint:md && npm run lint:js",
    "lint:fix": "npm run lint:styles -- --fix && npm run lint:js -- --fix && npm run prettier:fix",
    "prettier": "npx prettier .",
    "prettier:fix": "npx prettier . --write",
    "report:css-contract": "node scripts/write-css-contract-report.js",
    "report:token-contract": "node scripts/write-token-contract-report.js --json artifacts/token-contract.current.json --markdown artifacts/token-contract.current.md",
    "report:fixture-coverage": "node scripts/write-fixture-coverage-report.js",
    "test:unit": "mocha \"test/**/*.test.js\"",
    "test:visual:serve": "vite --port 4173 --strictPort",
    "test:visual:ui": "playwright test --config=playwright.visual.config.js --ui",
    "test:visual:a11y": "playwright test --config=playwright.visual.config.js --grep a11y --workers=1",
    "test:visual:parity": "playwright test --config=playwright.visual.config.js test/visual/parity.spec.js --workers=1",
    "test:visual:edge": "playwright test --config=playwright.visual.config.js test/visual/edge-cases.spec.js --workers=1",
    "test:visual": "npm run test:visual:a11y && npm run test:visual:parity && npm run test:visual:edge",
    "test": "npm run test:unit && npm run test:visual:a11y && npm run test:visual:parity && npm run test:visual:edge",
    "playwright:install": "playwright install chromium firefox webkit",
    "update:all": "npx npm-check-updates -u",
    "complete": "npm run build && npm run test && npm run lint:fix && npm run prettier:fix",
    "complete:check": "npm run build && npm run test && npm run lint && npm run prettier",
    "publish:public": "npm run complete && npm publish --access public"
  },
  "files": [
    "dist",
    "src",
    "index.css",
    "index.scss",
    "_settings.scss",
    "_styles.scss",
    "_tools.scss",
    "LICENSE"
  ],
  "dependencies": {
    "@guebbit/css-toolkit": "^1.4.1"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.13",
    "@eslint/js": "^9.39.4",
    "@guebbit/css-ui-v1": "npm:@guebbit/css-ui@1.3.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.4",
    "chai": "^6.2.2",
    "cssnano": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "markdownlint-cli2": "^0.22.1",
    "mocha": "^11.7.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.8",
    "postcss-extend-rule": "^4.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-prefix-selector": "^2.1.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guebbit/css-ui.git"
  },
  "keywords": [
    "SCSS",
    "Library"
  ],
  "author": {
    "name": "Guebbit",
    "email": "guerzoni.andrea91@gmail.com",
    "url": "https://guebbit.com/"
  },
  "license": "AGPL-3.0-or-later",
  "browserslist": {
    "production": [
      ">0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "bugs": {
    "url": "https://github.com/Guebbit/css-ui/issues"
  },
  "homepage": "https://github.com/Guebbit/css-ui"
}
